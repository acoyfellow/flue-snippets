{
  "name": "flue-snippets",
  "version": "0.0.1",
  "private": true,
  "description": "Real, runnable Flue agents on Cloudflare. Each example shows one CF product; each recipe composes several. Every snippet ships an end-to-end test that deploys an ephemeral Worker, asserts, and tears it down.",
  "type": "module",
  "scripts": {
    "rx:lab-receipt": "bash recipes/lab-receipt/run-e2e.sh",
    "rx:do-session": "bash recipes/do-session/run-e2e.sh",
    "rx:do-governor": "bash recipes/do-governor/run-e2e.sh",
    "rx:lab-checkpoint": "bash recipes/lab-checkpoint/run-e2e.sh",
    "rx:ai-gateway": "bash recipes/ai-gateway/run-e2e.sh",
    "rx:gateway-lab": "bash recipes/gateway-lab/run-e2e.sh",
    "rx:github-triage": "bash recipes/github-triage/run-e2e.sh",
    "rx:chat-thinking": "bash recipes/chat-thinking/run-e2e.sh",
    "rx:virtual-sandbox": "bash recipes/virtual-sandbox/run-e2e.sh",
    "rx:mcp-client": "bash recipes/mcp-client/run-e2e.sh",
    "rx:dynamic-workflow": "bash recipes/dynamic-workflow/run-e2e.sh",
    "tpl:github-app": "bash templates/github-app/run-e2e.sh",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "ex:ai-gateway": "bash scripts/run-example.sh ai-gateway",
    "ex:browser-rendering": "bash scripts/run-example.sh browser-rendering",
    "ex:d1": "bash scripts/run-example.sh d1",
    "ex:durable-objects": "bash scripts/run-example.sh durable-objects",
    "ex:email-workers": "bash scripts/run-example.sh email-workers",
    "ex:hyperdrive": "bash scripts/run-example.sh hyperdrive",
    "ex:kv": "bash scripts/run-example.sh kv",
    "ex:queues": "bash scripts/run-example.sh queues",
    "ex:r2": "bash scripts/run-example.sh r2",
    "ex:vectorize": "bash scripts/run-example.sh vectorize",
    "ex:worker-loader": "bash scripts/run-example.sh worker-loader",
    "ex:workers-ai": "bash scripts/run-example.sh workers-ai",
    "ex": "bash scripts/run-example.sh"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@flue/cli": "^0.3.11",
    "@flue/sdk": "^0.3.11",
    "@types/bun": "latest",
    "alchemy": "^0.93.7",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@acoyfellow/lab": "^0.0.3",
    "@cloudflare/puppeteer": "^1.1.0",
    "@cloudflare/think": "latest",
    "@octokit/core": "^6.1.2",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "agents": "^0.12.3",
    "gateproof": "latest",
    "postgres": "^3.4.4",
    "valibot": "^1.0.0",
    "workers-ai-provider": "^0.5.0",
    "zod": "^3.23.0"
  }
}
