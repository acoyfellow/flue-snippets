{
  "name": "flue-snippets",
  "version": "0.0.1",
  "private": true,
  "description": "Hero snippets where each one is a Flue agent + a Jordan primitive + a Cloudflare primitive. Each snippet ships with an E2E test that hits real hosted services. Green = the composition works. Red = the bug list.",
  "type": "module",
  "scripts": {
    "test": "bun test",
    "test:01": "bun test batch-a/01-lab-receipt",
    "test:02": "bun test batch-a/02-deja-memory",
    "test:03": "bun test batch-a/03-gateproof-loop",
    "test:08": "bun test batch-b/08-do-session"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.10.0",
    "@types/bun": "latest",
    "typescript": "^5.9.3",
    "vitest": "^3.1.0"
  },
  "dependencies": {
    "@acoyfellow/lab": "^0.0.3",
    "deja-jordan": "github:acoyfellow/deja",
    "gateproof": "latest",
    "unsurf": "latest"
  }
}
