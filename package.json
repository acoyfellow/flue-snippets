{
  "name": "flue-snippets",
  "version": "0.0.1",
  "private": true,
  "description": "Small Flue agents that compose with Cloudflare primitives. Each snippet ships with a real end-to-end test that deploys an ephemeral Worker, exercises it against live services, and tears it down.",
  "type": "module",
  "scripts": {
    "e2e:lab-receipt": "bash snippets/lab-receipt/run-e2e.sh",
    "e2e:do-session": "bash snippets/do-session/run-e2e.sh",
    "e2e:do-governor": "bash snippets/do-governor/run-e2e.sh",
    "e2e:lab-checkpoint": "bash snippets/lab-checkpoint/run-e2e.sh",
    "e2e:ai-gateway": "bash snippets/ai-gateway/run-e2e.sh",
    "e2e:gateway-lab": "bash snippets/gateway-lab/run-e2e.sh"
  },
  "devDependencies": {
    "@flue/cli": "^0.3.11",
    "@flue/sdk": "^0.3.11",
    "@types/bun": "latest",
    "alchemy": "^0.93.7",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@acoyfellow/lab": "^0.0.3",
    "agents": "^0.12.3",
    "gateproof": "latest"
  }
}
