---
interface Props {
  slug: string;
  title: string;
  tagline: string;
  composes: string[];
  /** The parent path on GitHub: 'examples' | 'recipes' | 'templates' */
  githubPath: string;
}

const { slug, title, tagline, composes, githubPath } = Astro.props as Props;
const href = `https://github.com/acoyfellow/flue-snippets/tree/main/${githubPath}/${slug}`;
const composesJson = JSON.stringify(composes);
---

<article
  class="card"
  data-snippet
  data-title={title}
  data-tagline={tagline}
  data-composes={composesJson}
>
  <h3 class="card-title">{title}</h3>
  <p class="card-tagline">{tagline}</p>
  <ul class="pills">
    {composes.map((c) => <li class="pill">{c}</li>)}
  </ul>
  <a class="card-link" href={href}>View on GitHub →</a>
</article>

<style>
  .card {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.25rem;
    height: 100%;
  }
  .card-title {
    font-family: var(--font-mono);
    font-size: 1rem;
    margin: 0;
  }
  .card-tagline {
    color: var(--muted);
    margin: 0;
    font-size: 0.95rem;
    flex: 1;
  }
  .pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .pill {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    background: var(--pill-bg);
    color: var(--pill-fg);
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
  }
  .card-link {
    font-size: 0.9rem;
    margin-top: 0.25rem;
  }
</style>
