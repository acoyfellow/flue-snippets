---
import '~/styles/global.css';
import Hero from '~/components/Hero.astro';
import WhyFlue from '~/components/WhyFlue.astro';
import Step from '~/components/Step.astro';
import Grid from '~/components/Grid.astro';
import FAQ from '~/components/FAQ.astro';
import { loadSnippets, type Snippet } from '~/lib/snippets';

const examples = await loadSnippets('examples');
const recipes = await loadSnippets('recipes');
const templates = await loadSnippets('templates');

// Combined catalog, examples first then recipes then templates, each
// alphabetical within its group.
const allSnippets: Snippet[] = [...examples, ...recipes, ...templates];

// Tour code blocks. Kept inline (verbatim from each snippet file) so the
// page renders with no async file reads. If a snippet changes, update
// the matching block here, flagged for future build-time auto-extract.

const workersAiCode = `import type { FlueContext } from '@flue/sdk/client';

interface Env {
  AI: { run: (model: string, args: unknown) => Promise<{ response: string }> };
}

export const triggers = { webhook: true };

export default async function ({ payload, env }: FlueContext & { env: Env }) {
  const out = await env.AI.run('@cf/moonshotai/kimi-k2.6', {
    prompt: payload.message ?? 'Say hi.',
  });
  return { answer: out.response };
}`;

const doSessionCode = `import type { FlueContext } from '@flue/sdk/client';

export const triggers = { webhook: true };

// POST /agents/do-session/<userId>
// Same userId = same Durable Object = same conversation. New userId = fresh agent.
export default async function ({ init, payload }: FlueContext) {
  const agent = await init({
    model: 'cloudflare-workers-ai/@cf/moonshotai/kimi-k2.6',
  });
  const session = await agent.session();
  const answer = await session.prompt(payload.message);
  return { answer };
}`;

const virtualSandboxCode = `import type { FlueContext } from '@flue/sdk/client';
import { getVirtualSandbox } from '@flue/sdk/cloudflare';

interface Env {
  KB: R2Bucket;
}

export const triggers = { webhook: true };

export default async function ({ init, payload, env }: FlueContext & { env: Env }) {
  // Mount the R2 bucket as a virtual filesystem. The agent gets grep,
  // find, and read over real R2 objects.
  const sandbox = await getVirtualSandbox(env.KB);

  const agent = await init({
    sandbox,
    model: 'cloudflare-workers-ai/@cf/moonshotai/kimi-k2.6',
  });
  const session = await agent.session();

  return await session.prompt(
    \`Answer this using only what you can grep from /workspace/docs: \${payload.message}\`,
  );
}`;

const mcpClientCode = `import { connectMcpServer, type FlueContext } from '@flue/sdk/client';

interface Env {
  MCP_URL: string;
}

export const triggers = { webhook: true };

export default async function ({ init, payload, env }: FlueContext & { env: Env }) {
  const mcp = await connectMcpServer('reverser', { url: env.MCP_URL });

  try {
    const harness = await init({
      model: 'cloudflare-workers-ai/@cf/moonshotai/kimi-k2.6',
      tools: mcp.tools,
    });
    const session = await harness.session();
    return await session.prompt(\`Reverse this: "\${payload.text}"\`);
  } finally {
    await mcp.close();
  }
}`;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Flue on Cloudflare</title>
    <meta
      name="description"
      content="Four agents I built with Flue on Cloudflare Workers, smallest to largest. Each one ships real code and a deploy command."
    />

    {/* Open Graph + Twitter card */}
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://flue.coey.dev/" />
    <meta property="og:title" content="Flue on Cloudflare" />
    <meta
      property="og:description"
      content="Four agents I built with Flue on Cloudflare Workers, smallest to largest."
    />
    <meta property="og:image" content="https://flue.coey.dev/og/index.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content="Flue on Cloudflare. Four agents I built, smallest to largest. Real code, real deploys."
    />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Flue on Cloudflare" />
    <meta
      name="twitter:description"
      content="Four agents I built with Flue on Cloudflare Workers, smallest to largest."
    />
    <meta name="twitter:image" content="https://flue.coey.dev/og/index.png" />
    <meta
      name="twitter:image:alt"
      content="Flue on Cloudflare. Four agents I built, smallest to largest. Real code, real deploys."
    />

    <link rel="preload" href="/fonts/inter-400.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/jetbrains-mono-500.woff2" as="font" type="font/woff2" crossorigin />
  </head>
  <body>
    <a class="skip-link" href="#step-1">Skip to the first agent</a>
    <main class="container">
      <Hero />
      <WhyFlue />

      <section class="quickstart">
        <h2>Run one yourself</h2>
        <p class="muted">
          Each agent below has a one-liner you can run. They all deploy to your CF account,
          assert, then destroy the Worker.
        </p>
        <pre><code>git clone https://github.com/acoyfellow/flue-snippets
cd flue-snippets
bun install        # or: npm install
export CLOUDFLARE_API_TOKEN=...
export CLOUDFLARE_ACCOUNT_ID=...
bun ex:workers-ai  # or: npm run ex:workers-ai</code></pre>
      </section>

      <Step
        id="step-1"
        title="1. Call a model. Return the answer."
        blurb="The smallest thing I could build. Bind Workers AI, run a prompt, return the response. Flue gives it an HTTP endpoint at /agents/workers-ai/<id>. The whole agent is 13 lines."
        filename="examples/workers-ai/workers-ai.ts"
        code={workersAiCode}
        githubPath="examples/workers-ai/workers-ai.ts"
      >
        <p class="muted">
          What surprised me: only two things here are Flue's, the <code>triggers</code> export
          and the <code>FlueContext</code> type. Everything else is plain Cloudflare. Flue
          handled the routing and gave the rest somewhere to live.
        </p>
      </Step>

      <Step
        title="2. Make it remember things"
        blurb="Same code, but now I call session() and prompt(). Two POSTs to /agents/do-session/alice keep talking to the same Durable Object. The agent remembers what alice said earlier. Different path id, different DO, fresh conversation. I didn't wire any of this up."
        filename="recipes/do-session/agents/do-session.ts"
        code={doSessionCode}
        githubPath="recipes/do-session/agents/do-session.ts"
      >
        <p class="muted">
          Cloudflare's part: Durable Objects with SQLite, geo-pinned to the user. Flue's
          part: <code>session()</code> figures out which DO to talk to and stores the
          messages for you. I never wrote SQL or touched DO RPC.
        </p>
      </Step>

      <Step
        title="3. Give it a real filesystem"
        blurb="getVirtualSandbox() mounts an R2 bucket as /workspace. The model now has grep, find, and read inside the prompt loop. I dumped some markdown into R2, asked a question, and watched the agent grep through it to find the answer."
        filename="recipes/virtual-sandbox/agents/virtual-sandbox.ts"
        code={virtualSandboxCode}
        githubPath="recipes/virtual-sandbox/agents/virtual-sandbox.ts"
      >
        <p class="muted">
          No vector DB, no embedding pipeline. For a lot of "search my docs" use cases this
          works fine, the model just runs grep. The shell underneath is{' '}
          <code>just-bash</code>, running right inside the Worker. R2 is the storage.
        </p>
      </Step>

      <Step
        title="4. Talk to another Worker over MCP"
        blurb="This Flue agent connects to a peer Worker that exposes tools via MCP. alchemy deploys both side by side and passes the peer's URL into this one's env. The model can now call the peer's tools mid-prompt. I didn't have to wire each one up manually."
        filename="recipes/mcp-client/agents/mcp-client.ts"
        code={mcpClientCode}
        githubPath="recipes/mcp-client/agents/mcp-client.ts"
      >
        <p class="muted">
          The peer is just another Worker , 
          <a href="https://github.com/acoyfellow/flue-snippets/blob/main/recipes/mcp-client/mcp-server.ts">
            mcp-server.ts</a
          > using <code>McpAgent</code> from the <code>agents</code> SDK. Nice side effect:
          the model never sees the peer's credentials, just its tools. Auth stays on the
          server side.
        </p>
      </Step>

      <section class="more">
        <h2>The rest of the repo</h2>
        <p class="muted">
          Those were four. There are {allSnippets.length} total, every one runnable on your
          own CF account. Each row links to the snippet's folder on GitHub.
        </p>
        <Grid snippets={allSnippets} caption="All snippets in the repo" />
      </section>

      <FAQ />

      <footer class="footer muted">
        <p>
          <a href="https://github.com/acoyfellow/flue-snippets">Source</a>
          <span> · </span>
          <a href="https://flueframework.com">Flue</a>
          <span> · </span>
          <a href="https://developers.cloudflare.com/workers/">Cloudflare Workers</a>
          <span> · </span>
          <a href="https://coey.dev">coey.dev</a>
        </p>
      </footer>
    </main>
  </body>
</html>

<style>
  .quickstart {
    margin: var(--space-6) 0 var(--space-7);
  }
  .quickstart h2 {
    margin-top: 0;
  }
  .quickstart pre {
    margin-bottom: 0;
  }
  .more {
    margin-top: var(--space-7);
  }
  .footer {
    margin-top: var(--space-7);
    padding-top: var(--space-5);
    border-top: 1px solid var(--border);
    font-size: var(--text-sm);
  }
</style>
